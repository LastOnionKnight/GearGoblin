<Project Sdk="Dalamud.NET.Sdk/15.0.0">

  <PropertyGroup>
    <Author>LastOnionKnight</Author>
    <Name>GearGoblin</Name>
    <InternalName>GearGoblin</InternalName>
    <AssemblyVersion>0.1.4.0</AssemblyVersion>
    <FileVersion>0.1.4.0</FileVersion>
    <Version>0.1.4.0</Version>
    <MinimumDalamudVersion>15.0.0</MinimumDalamudVersion>
    <Punchline>BiS planner with acquisition tracking and materia advisor.</Punchline>
    <Description>BiS planner with acquisition tracking and materia advisor for FFXIV. Reads your gear, compares against an Etro/XIVGear BiS or a casual stat-priority preset, and tells you what to farm next, what to meld, and what not to bother melding.</Description>
    <RepoUrl>https://github.com/LastOnionKnight/GearGoblin</RepoUrl>
    <Tags>gear;bis;materia;raid;etro</Tags>

    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

</Project>
