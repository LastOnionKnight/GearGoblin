    <MinimumDalamudVersion>15.0.0</MinimumDalamudVersion>
    <Punchline>BiS planner, Materia Advisor, and round-trip optimizer for FFXIV. The in-game half of Tonberry Tactics; coexists with CharacterPanelRefined.</Punchline>
    <Description>In-game half of Tonberry Tactics. v0.6.7 begins the Track 2 (ember/frost-blue) visual era with the Plan tab repainted as the first surface. New Theme/TtChrome.cs module provides the doubled-frame card chrome (outer 2px frost-outline + inner 1px hairline at 6px inset) plus the ember/frost-blue palette lifted from the TLF HUD v0.1 design handoff. FontAtlasManager gains five Track 2 font handles (Cormorant Garamond, JetBrains Mono, Eorzea rune) â€” all optional, no callers wired yet. Plan tab data flow unchanged; only the chrome changes. Core and Web at v0.6.7 lockstep (version-only).</Description>
    <RepoUrl>https://github.com/LastOnionKnight/GearGoblin</RepoUrl>
    <Tags>gear;bis;materia;etro;xivgear;raid;advisor;cpr;character-panel;tonberry-tactics</Tags>

    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <DefaultItemExcludes>$(DefaultItemExcludes);external\**</DefaultItemExcludes>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Assets\**\*.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Pack>true</Pack>
    </Content>
    <None Include="Assets\circle-logo.png" CopyToOutputDirectory="PreserveNewest" />
    <None Include="Assets\rags-portrait.png" CopyToOutputDirectory="PreserveNewest" />
    <None Include="Assets\rags-mini.png" CopyToOutputDirectory="PreserveNewest" />
    <None Include="Assets\lantern-mark.png" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\about-changelog.txt" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\Fonts\*.ttf">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Pack>true</Pack>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="external\GearGoblin.Core\GearGoblin.Core\GearGoblin.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="*-dropin\**\*.cs" />
    <Compile Remove="**\*-dropin\**\*.cs" />
    <None Remove="*-dropin\**" />
    <None Remove="**\*-dropin\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.8" />
  </ItemGroup>
</Project>










